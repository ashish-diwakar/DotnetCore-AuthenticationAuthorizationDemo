@if (User is not null && User.Identity is not null && User.Identity.IsAuthenticated && User.Claims.Count() > 0 && User.Claims.Any(x => x.Type == "Position"))
{
    <form method="post" class="form-inline" asp-page="/Account/Logout">
        Welcome @User.Identity.Name! (@User?.Claims?.First(x => x.Type == "Position"))
        <button type="submit" class="nav-link btn btn-link text-bg-warning d-inline p-2">Logout</button>
    </form>
}
else if (User is not null && User.Identity is not null && User.Identity.IsAuthenticated)
{
    <form method="post" class="form-inline" asp-page="/Account/Logout">
        Welcome @User.Identity.Name!
        <button type="submit" class="nav-link btn btn-link text-bg-warning d-inline p-2">Logout</button>
    </form>
}
else
{
    <a class="nav-link btn btn-link text-bg-warning d-inline p-2" asp-page="/Account/Login">Login</a>
}