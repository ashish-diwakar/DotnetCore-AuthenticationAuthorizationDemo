@page
@model SecurityDemo.Pages.HrManagementModel
@{
}
<div class="align-content-center">
    <h1 class="text-center">HR Management</h1>
    <p class="text-center">This page is only accessible to users with the "HRManager" role.</p>
</div>
<br />

@if(Model.weatherForcastItems is not null)
{
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Date</th>
                <th>Summary</th>
                <th>Temperature (°C)</th>
                <th>Temperature (°F)</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.weatherForcastItems)
            {
                <tr>
                    <td>@item.Date.ToShortDateString()</td>
                    <td>@item.Summary</td>
                    <td>@item.TemperatureC</td>
                    <td>@item.TemperatureF</td>
                </tr>
            }
        </tbody>
    </table>
}