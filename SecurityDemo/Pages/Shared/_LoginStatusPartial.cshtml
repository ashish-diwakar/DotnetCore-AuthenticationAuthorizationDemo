@if (User is not null && User.Identity is not null && User.Identity.IsAuthenticated)
{
    <form method="post" class="form-inline" asp-page="/Account/Logout">
        Welcome @User.Identity.Name!
        <button type="submit" class="nav-link btn btn-link text-bg-warning d-inline p-2">Logout</button>
    </form>
}
else
{
    <a class="nav-link btn btn-link text-bg-warning d-inline p-2" asp-page="/Account/Login">Login</a>
}